# Local dev: omit VITE_API_URL — client defaults to /api (Vite proxy in vite.config.js).
# Production (Vercel): set both to your Render URL, e.g.:
# VITE_API_URL=https://your-api.onrender.com/api
# VITE_BACKEND_URL=https://your-api.onrender.com
VITE_BACKEND_URL=http://localhost:5000

# Optional: Cloudinary cloud name. The backend already returns this
# from /api/admin/uploads/signature, so the frontend rarely needs it.
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
