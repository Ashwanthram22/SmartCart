# Required in production. Must be at least 16 chars and not the placeholder
# below (otherwise the server refuses to boot in production and warns in dev).
JWT_SECRET=change_this_secret_to_something_long_random_and_secret
JWT_EXPIRES_IN=30d

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Must match the URL shown when you run `npm run dev` in Frontend (see vite.config.js port).
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list of allowed origins for CORS. Defaults to FRONTEND_URL.
# CORS_ORIGINS=http://localhost:5173,https://smartcart.app

# NODE_ENV=production
# PORT=5000

# Shopping assistant (chatbot). Defaults to a built-in rule-based engine
# that needs no external service. To upgrade to a real LLM, pick one provider
# below and supply its API key. The rule-based engine stays in place as the
# automatic fallback if the LLM call fails.
#
# Recommended for hobby / dev: Gemini (1,500 req/day free, no card required).
# ASSISTANT_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Or OpenAI (paid; new accounts get $5 free credit, expires in 3 months):
# ASSISTANT_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Max time (ms) for one assistant /chat reply before the server returns 504. Clamped 5000–120000.
# ASSISTANT_GENERATION_TIMEOUT_MS=45000

# MongoDB (optional). The app uses src/data/db.json until USE_MONGO=true and routes are migrated.
# See src/lib/mongo/README.md for the cutover checklist.
# USE_MONGO=true
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/smartcart?retryWrites=true&w=majority

# ----- Cloudinary (admin product image uploads) -----
# Either set the three values below, OR set CLOUDINARY_URL — both are read.
# Find them under "API Keys" in your Cloudinary console (https://console.cloudinary.com/).
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# Optional: change the folder uploads land in (defaults to smartcart/products).
# CLOUDINARY_UPLOAD_FOLDER=smartcart/products
